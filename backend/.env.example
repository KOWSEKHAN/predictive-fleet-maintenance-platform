# .env.example — Environment variable template for FleetCare AI Platform
# ─────────────────────────────────────────────────────────────────────────────
# SETUP:
#   cp .env.example .env
#   Fill in all values marked <REQUIRED>
#   NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────

# Secret key used for cryptographic signing. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<REQUIRED>

# Set to True ONLY for local development. Always False in production.
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames.
# Include your Render hostname after first deploy.
# Example: localhost,127.0.0.1,myfleet-platform.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Render provides this automatically).
# If unset, falls back to local SQLite — fine for development.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# Include your Vercel URL after deploy.
# Example: http://localhost:3000,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── JWT Tokens ────────────────────────────────────────────────────────────────

# Access token lifetime in minutes (default: 1440 = 24 hours)
JWT_ACCESS_MINUTES=1440

# Refresh token lifetime in days (default: 7 days)
JWT_REFRESH_DAYS=7
